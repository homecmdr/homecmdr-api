meta {
  name: Create Room
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/rooms
  body: json
  auth: bearer
}

headers {
  content-type: application/json
}

auth:bearer {
  token: change-me-before-use
}

body:json {
  {
    "id": "bedroom",
    "name": "Bedroom"
  }
}

vars:pre-request {
  baseUrl: 127.0.0.1:3001
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
