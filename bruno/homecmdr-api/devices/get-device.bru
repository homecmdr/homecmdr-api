meta {
  name: Get Device
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/devices/:id
  body: none
  auth: none
}

params:path {
  id: {{deviceId}}
}

vars:pre-request {
  baseUrl: 127.0.0.1:3001
  deviceId: open_meteo:humidity
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
