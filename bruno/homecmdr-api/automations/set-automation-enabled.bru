meta {
  name: Set Automation Enabled
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/automations/:id/enabled
}

params:path {
  id: {{automationId}}
}

headers {
  content-type: application/json
}

body {
  {
    "enabled": true
  }
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
