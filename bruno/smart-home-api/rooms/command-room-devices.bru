meta {
  name: Command Room Devices
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/rooms/:id/command
  body: json
  auth: bearer
}

params:path {
  id: {{roomId}}
}

headers {
  content-type: application/json
}

auth:bearer {
  token: change-me-before-use
}

body:json {
  {
    "capability": "power",
    "action": "off"
  }
}

vars:pre-request {
  roomId: bedroom
  baseUrl: 127.0.0.1:3001
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
