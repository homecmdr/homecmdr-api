meta {
  name: List Room Devices
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/rooms/:id/devices
  body: none
  auth: none
}

params:path {
  id: {{roomId}}
}

vars:pre-request {
  baseUrl: 127.0.0.1:3001
  roomId: bedroom
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
