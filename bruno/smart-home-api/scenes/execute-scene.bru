meta {
  name: Execute Scene
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/scenes/:id/execute
  body: none
  auth: bearer
}

params:path {
  id: {{sceneId}}
}

auth:bearer {
  token: change-me-before-use
}

vars:pre-request {
  baseUrl: 127.0.01:3001
  sceneId: bedtime
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
